---
layout: layouts/base.njk
title: Links
permalink: /links/
fullBleed: true
description: Contact and profiles elsewhere on the web.
---
<section class="section page">
  <div class="section-inner">
    <header class="page-header">
      <h1 class="section-heading">Links</h1>
      <p class="section-lead">Email, social profiles, and places to follow along outside this site.</p>
    </header>

    <div class="links-group">
      <h2 class="subsection-heading">Contact</h2>
      <div class="links-grid">
        <a class="link-card" href="mailto:{{ site.email }}">
          <span class="link-label">Email</span>
          <span class="link-value">{{ site.email }}</span>
        </a>
        <a class="link-card" href="{{ site.calendly }}" rel="noopener noreferrer">
          <span class="link-label">Calendly</span>
          <span class="link-value">Schedule a call</span>
        </a>
      </div>
    </div>

    <div class="links-group">
      <h2 class="subsection-heading">Social</h2>
      <div class="links-grid">
        <a class="link-card" href="{{ site.linkedin }}" rel="noopener noreferrer">
          <span class="link-label">LinkedIn</span>
          <span class="link-value">Professional profile</span>
        </a>
        <a class="link-card" href="{{ site.github }}" rel="noopener noreferrer">
          <span class="link-label">GitHub</span>
          <span class="link-value">Code and open source</span>
        </a>
        <a class="link-card" href="{{ site.twitter }}" rel="noopener noreferrer">
          <span class="link-label">X</span>
          <span class="link-value">@onerinas</span>
        </a>
        <a class="link-card" href="{{ site.wip }}" rel="noopener noreferrer">
          <span class="link-label">WIP</span>
          <span class="link-value">Projects in progress</span>
        </a>
      </div>
    </div>

    <div class="links-group">
      <h2 class="subsection-heading">Follow</h2>
      <div class="links-grid">
        <a class="link-card" href="{{ site.newsletter }}" rel="noopener noreferrer">
          <span class="link-label">Newsletter</span>
          <span class="link-value">Occasional updates via Buttondown</span>
        </a>
      </div>
    </div>
  </div>
</section>
