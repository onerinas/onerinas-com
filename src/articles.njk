---
layout: layouts/base.njk
title: Blog
permalink: /articles/
fullBleed: true
description: Articles and notes on software, indie projects, and life.
---
<section class="section page">
  <div class="section-inner">
    <header class="page-header">
      <h1 class="section-heading">Blog</h1>
      <p class="section-lead">TIL posts and notes on software, indie projects, and life. <a href="/feed.xml">RSS</a></p>
    </header>

    <div class="article-group">
      <h2 class="subsection-heading">TIL</h2>
      <ul class="article-list">
      {%- for post in collections.articles | byTopic("til") %}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        </li>
      {%- endfor %}
      </ul>
    </div>

    <div class="article-group">
      <h2 class="subsection-heading">Notes</h2>
      <ul class="article-list">
      {%- for post in collections.articles | byTopic("notes") %}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        </li>
      {%- endfor %}
      </ul>
    </div>
  </div>
</section>
