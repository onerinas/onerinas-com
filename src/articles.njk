---
layout: layouts/base.njk
title: Blog
permalink: /articles/
fullBleed: true
description: Articles and notes on software, indie projects, and life.
---
<section class="section section-page-intro">
  <div class="section-inner">
    <h1 class="section-heading">Blog</h1>
    <p class="section-lead">Software, indie projects, and navigating life. <a href="/feed.xml">RSS</a></p>
  </div>
</section>

<section class="section section-posts">
  <div class="section-inner">
    <div class="article-group">
      <h2 class="article-group-heading">TIL</h2>
      <ul class="article-list">
      {%- for post in collections.articles | byTopic("til") %}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        </li>
      {%- endfor %}
      </ul>
    </div>

    <div class="article-group">
      <h2 class="article-group-heading">Notes</h2>
      <ul class="article-list">
      {%- for post in collections.articles | byTopic("notes") %}
        <li>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        </li>
      {%- endfor %}
      </ul>
    </div>
  </div>
</section>
