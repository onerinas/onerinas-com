---
layout: layouts/base.njk
permalink: /
fullBleed: true
description: TIL posts and notes on software, indie projects, and life.
---
<section class="section page">
  <div class="section-inner">
    <header class="page-header">
      <h1 class="section-heading">Writing</h1>
      <p class="section-lead">TIL posts and notes on software, indie projects, and life. <a href="/feed.xml">RSS</a></p>
    </header>

    <ul class="article-list">
    {%- for post in collections.articles %}
      {%- if loop.index0 < 5 %}
      <li>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
      </li>
      {%- endif %}
    {%- endfor %}
    </ul>

    <p class="section-footer-link"><a class="btn btn-pill" href="/articles/">All articles →</a></p>
  </div>
</section>
