<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#1a1a1a">
  {% include "partials/seo-head.njk" %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }} | Articles" href="/feed.xml">
  {% include "partials/json-ld.njk" %}
</head>
<body{% if fullBleed %} class="page-full-bleed"{% endif %}>
  <header class="site-header">
    <div class="container">
      <a class="site-title" href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>{{ site.name }}</a>
      <nav aria-label="Main">
        <ul class="nav">
          <li><a href="/about/"{% if page.url == "/about/" %} aria-current="page"{% endif %}>About</a></li>
          <li><a href="/work/"{% if page.url == "/work/" %} aria-current="page"{% endif %}>Work</a></li>
          <li><a href="/projects/"{% if page.url == "/projects/" %} aria-current="page"{% endif %}>Projects</a></li>
          <li><a href="/articles/"{% if page.url == "/articles/" or (tags is defined and "articles" in tags) %} aria-current="page"{% endif %}>Blog</a></li>
          <li><a href="/links/"{% if page.url == "/links/" %} aria-current="page"{% endif %}>Links</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="footer-copy">&copy; {{ currentYear }} {{ site.name }}</p>
    </div>
  </footer>
  {%- if env.isProd and env.fathomSiteId %}
  <script src="https://cdn.usefathom.com/script.js" data-site="{{ env.fathomSiteId }}" defer></script>
  {%- endif %}
</body>
</html>
