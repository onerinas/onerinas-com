<div class="page-section">
  <h2 class="subsection-heading">Get in touch</h2>
  <div class="contact-grid">
    <a class="contact-card" href="mailto:{{ site.email }}">
      <span class="contact-label">Email</span>
      <span class="contact-value">{{ site.email }}</span>
    </a>
    <a class="contact-card" href="{{ site.calendly }}" rel="noopener noreferrer">
      <span class="contact-label">Calendly</span>
      <span class="contact-value">Schedule a call</span>
    </a>
  </div>
</div>
