<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">{{ site.name }}</h1>
    <p class="hero-intro">{{ site.tagline }}</p>
    <p class="hero-location">
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      {{ site.location }}
    </p>
    <ul class="tech-stack" aria-label="Skills">
      {%- for item in site.techStack %}
      <li class="tech-item">{{ item }}</li>
      {%- endfor %}
    </ul>
    <div class="hero-contact">
      <a class="btn btn-outline" href="mailto:{{ site.email }}">{{ site.email }}</a>
      <a class="btn btn-outline" href="{{ site.calendly }}">Schedule a call on Calendly</a>
    </div>
  </div>
</section>
