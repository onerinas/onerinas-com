{
  "name": "onerinas",
  "private": true,
  "description": "Personal site and blog — onerinas.com",
  "scripts": {
    "redirects": "node scripts/generate-redirects.js",
    "import:blog": "node scripts/import-from-blog.js",
    "fix:escapes": "node scripts/fix-markdown-escapes.js",
    "assign:topics": "node scripts/assign-topics.js",
    "og": "node scripts/generate-og-images.js",
    "build": "npm run redirects && npx @11ty/eleventy && npm run og",
    "dev": "npm run redirects && npx @11ty/eleventy --serve",
    "start": "npm run dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@fontsource/inter": "^5.2.8",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
